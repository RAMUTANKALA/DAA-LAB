#include<stdio.h>
#define INF 999

int main()
{
    int cost[10][10], visited[10];
    int i,j,n,ne=1;
    int min,a,b,u,v;
    int mincost=0;

    printf("Enter number of vertices: ");
    scanf("%d",&n);

    printf("Enter cost matrix:\n");

    for(i=1;i<=n;i++)
    {
        for(j=1;j<=n;j++)
        {
            scanf("%d",&cost[i][j]);

            if(cost[i][j]==0)
                cost[i][j]=INF;
        }
    }

    visited[1]=1;

    while(ne < n)
    {
        min = INF;

        for(i=1;i<=n;i++)
        {
            for(j=1;j<=n;j++)
            {
                if(cost[i][j] < min)
                {
                    if(visited[i]!=0)
                    {
                        min = cost[i][j];
                        a=u=i;
                        b=v=j;
                    }
                }
            }
        }

        if(visited[u]==0 || visited[v]==0)
        {
            printf("Edge %d:(%d %d) cost:%d\n",ne++,a,b,min);
            mincost += min;
            visited[b]=1;
        }

        cost[a][b] = cost[b][a] = INF;
    }

    printf("Minimum cost = %d",mincost);

    return 0;
}
