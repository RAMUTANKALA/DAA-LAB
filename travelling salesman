#include <stdio.h>
#include <limits.h>
#define N 4

int min(int a, int b) {
    return (a < b) ? a : b;
}

int tsp(int graph[N][N], int visited[], int currPos, int count, int cost, int ans) {

    if (count == N && graph[currPos][0]) {
        ans = min(ans, cost + graph[currPos][0]);
        return ans;
    }

    for (int i = 0; i < N; i++) {
        if (visited[i] == 0 && graph[currPos][i]) {

            visited[i] = 1;
            ans = tsp(graph, visited, i, count + 1,
                      cost + graph[currPos][i], ans);
            visited[i] = 0;
        }
    }

    return ans;
}

int main() {

    int graph[N][N] = {
        {0,10,15,20},
        {10,0,35,25},
        {15,35,0,30},
        {20,25,30,0}
    };

    int visited[N] = {0};
    visited[0] = 1;

    int ans = INT_MAX;

    ans = tsp(graph, visited, 0, 1, 0, ans);

    printf("Minimum travelling cost = %d", ans);

    return 0;
}
